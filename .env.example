# ResidentOS local/server configuration.
# Copy to .env.local and replace placeholders locally. Do not commit real values.

# App runtime
PORT=3000
HOST=127.0.0.1
DEMO_MODE=true
RESIDENTOS_SELLER_ID=demo-seller
RESIDENTOS_ZELLE_RECIPIENT_NAME=replace-with-demo-recipient-name
RESIDENTOS_ZELLE_RECIPIENT_EMAIL=replace-with-demo-recipient-email

# InsForge server-side access
INSFORGE_URL=https://your-app-key.your-region.insforge.app
# Optional local alias used by some InsForge tooling; Render should still set INSFORGE_URL.
INSFORGE_BASE_URL=https://your-app-key.your-region.insforge.app
INSFORGE_APPKEY=your-app-key
INSFORGE_API_KEY=replace-with-insforge-server-api-key
INSFORGE_ANON_KEY=replace-with-optional-insforge-anon-key

# Tigris private artifact bucket
AWS_S3_BUCKET=residentos-artifacts
AWS_ENDPOINT_URL_S3=https://your-tigris-s3-endpoint
AWS_REGION=auto
AWS_ACCESS_KEY_ID=replace-with-tigris-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-tigris-secret-access-key

# NEAR AI OpenAI-compatible receipt extraction
NEAR_AI_BASE_URL=https://your-near-ai-openai-compatible-base-url
NEAR_AI_API_KEY=replace-with-near-ai-api-key
NEAR_AI_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct
RESIDENTOS_RECEIPT_FIXTURE_PATH=/home/andrew/Downloads/IMG_3195.png

# Optional verification targets
RESIDENTOS_DASHBOARD_URL=http://127.0.0.1:3000
RENDER_API_KEY=replace-with-render-api-key-for-cli-or-api-checks
